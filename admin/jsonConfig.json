          "sm": 6,
          "md": 4,
          "lg": 4,
          "xl": 4
        }
      }
    },
    "devicesTab": {
      "type": "panel",
      "label": "Devices",
      "items": {
        "devices": {
          "newLine": true,
          "type": "table",
          "label": "",
          "compact": true,
          "showSecondAddAt": 5,
          "useCardFor": [
            "xs",
            "sm"
          ],
          "titleAttribute": "name",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "items": [
            {
              "type": "text",
              "attr": "name",
              "title": "Name",
              "filter": false,
              "sort": false,
              "width": "34%",
              "default": ""
            },
            {
              "type": "text",
              "attr": "ip",
              "title": "IP Address",
              "filter": false,
              "sort": false,
              "width": "33%",
              "default": ""
            },
            {
              "type": "text",
